{
  "name": "shoe-ecomm",
  "version": "2.0.0",
  "description": "Advanced MERN Shoe E-commerce with live theming, multi-gateway payments and admin analytics",
  "type": "module",
  "main": "backend/server.js",
  "scripts": {
  "start": "node backend/server.js",
  "server": "nodemon backend/server.js",
  "client": "npm start --prefix frontend",
  "dev": "concurrently \"npm run server\" \"npm run client\"",
  "data:import": "node backend/seeder.js",
  "data:destroy": "node backend/seeder.js -d",
  "test": "vitest run",
  "test:watch": "vitest",
  "test:ui": "vitest --ui"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TahoshinIslam/Shoe_Ecommerce.git"
  },
  "author": "Tahoshin",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.50.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.12.1",
    "slugify": "^1.6.6",
    "stripe": "^17.3.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.7",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
